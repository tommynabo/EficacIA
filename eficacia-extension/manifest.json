{
  "manifest_version": 3,
  "name": "EficacIA Connector",
  "version": "1.1.0",
  "description": "Extrae leads de Sales Navigator y Apollo.io directamente a tus campañas de EficacIA.",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/sales/search/people*",
        "https://app.apollo.io/*",
        "https://*.apollo.io/*"
      ],
      "js": ["assets/content.js"]
    }
  ],
  "permissions": ["storage", "activeTab", "scripting", "alarms", "tabs"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://app.apollo.io/*",
    "https://*.apollo.io/*"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://app.apollo.io/*",
        "https://*.apollo.io/*"
      ],
      "resources": ["assets/content.js"],
      "use_dynamic_url": false
    }
  ]
}
