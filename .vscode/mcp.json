{
  "servers": {
    "stripe": {
      "command": "npx",
      "args": [
        "-y",
        "@stripe/mcp",
        "--api-key",
        "${input:stripeApiKey}"
      ],
      "inputs": [
        {
          "id": "stripeApiKey",
          "type": "promptString",
          "description": "Stripe secret key (sk_live_...)",
          "password": true
        }
      ]
    }
  }
}
