{
  "manifest_version": 3,
  "name": "EficacIA – LinkedIn Connector",
  "version": "1.0.0",
  "description": "Conecta tu cuenta LinkedIn a EficacIA con un solo clic. Sin copiar cookies manualmente.",
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.vercel.app/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "EficacIA – LinkedIn Connector",
    "default_popup": "popup.html"
  }
}
